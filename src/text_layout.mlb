(* sml-text-layout: public library basis.  The vendored sml-font chain (Font +
 * Image/Raster/Inflate/Color) and sml-unicode are each loaded exactly once,
 * then the text-layout sources. *)
$(SML_LIB)/basis/basis.mlb

../lib/github.com/sjqtentacles/sml-font/font.mlb
../lib/github.com/sjqtentacles/sml-unicode/sources.mlb

text_layout.sig
text_layout.sml
